HELP.md
/target/
!.mvn/wrapper/maven-wrapper.jar
# These are some examples of commonly ignored file patterns.
# You should customize this list as applicable to your project.
# Learn more about .gitignore:
#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# Node artifact files
node_modules/
dist/

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log
logs/

# Package files
*.jar

# Maven
target/
dist/

# JetBrains IDE
.idea/

# Unit test reports
TEST*.xml

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

# Test runtime: her testin ürettiği imzalı içerikler (XAdES/CAdES/PAdES/WSS).
# `SignedArtifactExporter` test başına buraya yazar — üçüncü taraf araçlarla
# (Adobe Reader, EU DSS Demo, xmlsec1, openssl smime, SoapUI) manuel olarak
# doğrulamak için. `target/` zaten exclude ama explicit netlik için:
target/signed-artifacts/
# Mutlak/custom yola taşımak isteyen geliştiriciler için fallback location:
signed-artifacts/

# Evidence Site local preview (scripts/serve-pages-locally.sh çıktıları).
# `publish-pages.yml` workflow'unda CI Pages'e push eder; local'de her
# koşumda yeniden üretilir → repo'ya commit etmeye gerek yok.
pages-output/
# Spring Boot snapshot + Scalar API Reference HTML template — script üretir.
openapi-snapshot/
# Allure trend history — workflow actions/cache@v4 ile saklar; local'de
# her run yeniden üretilebilir, repo'ya gömmeye değer değil.
.allure-history/
# allure-maven-plugin'in indirdiği Allure CLI binary (~28 MB).
# `mvn allure:report` ilk koşumda buraya çeker, sonraki run'larda
# cache'ten kullanır. Repo'ya commit edilmez — `mvn` her ortamda
# kendi versiyonunu indirir.
.allure/

.vscode

# ─── Geliştirici lokali credential override (AKİS kart PIN/ALIAS/SERIAL) ───
# `application-mali-muhur-akis-{linux,windows,mac}.properties` dosyaları bu
# dosyayı `spring.config.import=optional:file:` ile yükler. Repo'ya hiçbir
# zaman commit edilmez — kart bağımlı sırlar burada yaşar, run config XML'leri
# (.run/) tertemiz/değişmez kalır.
# Şablon: `local-secrets.properties.example` (commitlenir).
/local-secrets.properties
