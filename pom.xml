    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <!--
                    `mvn spring-boot:run` çalıştırıldığında otomatik olarak
                    'local' Spring profile'ı aktif olur → src/main/resources/
                    application-local.properties yüklenir → test PFX + dummy
                    config ile uygulama hemen ayağa kalkar. Geliştirici
                    elle PFX_PATH / CERTIFICATE_PIN env var set etmek
                    zorunda kalmaz.

                    Production deployment'ları `java -jar` ile çalıştırılır
                    (bu plugin'in goal'lerini değil); orada profile aktif
                    olmaz, prod-grade env var'lar zorunlu kalır.
                -->
                <configuration>
                    <profiles>
                        <profile>local</profile>
                    </profiles>
                </configuration>
                <executions>
                    <execution>
                        <configuration>
                            <mainClass>io.mersel.dss.signer.api.SignatureApplication</mainClass>
                        </configuration>
                    </execution>
                    <!--
                        build-info goal — Spring Boot'a özgü release metadata.
                        ===========================================================
                        Çıktı: target/classes/META-INF/build-info.properties
                        Runtime erişim:
                          - /actuator/info endpoint'i (management.info.build.enabled=true,
                            default açık)
                          - Spring DI: @Autowired BuildProperties
                          - Logback `%X{...}` MDC veya app içi audit log

                        Property'ler:
                          build.artifact, build.group, build.name, build.version
                          (otomatik POM'dan)
                          + additionalProperties:
                              revision      → git commit SHA (full veya abbrev)
                              buildNumber   → CI run number (örn. GITHUB_RUN_NUMBER)
                              buildTime     → ISO-8601 UTC timestamp
                              buildHost     → CI runner adı (örn. ubuntu-latest)

                        Bu sayede production'da çalışan instance'ın "tam olarak
                        hangi commit'ten ve hangi CI run'undan çıktığı" tek
                        HTTP çağrısıyla doğrulanabilir. Auditor için kanıt
                        zinciri tamamlanır.
                    -->
                    <execution>
                        <id>build-info</id>
                        <goals>
                            <goal>build-info</goal>
                        </goals>
                        <configuration>
                            <additionalProperties>
                                <revision>${mersel.build.revision}</revision>
                                <buildNumber>${mersel.build.number}</buildNumber>
                                <buildTime>${mersel.build.timestamp}</buildTime>
                                <buildHost>${mersel.build.host}</buildHost>
                                <buildJdk>${java.version}</buildJdk>
                                <buildOs>${os.name} ${os.arch}</buildOs>
                            </additionalProperties>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!--
                maven-jar-plugin — Standart MANIFEST.MF entry'leri.
                ==========================================================
                Spring Boot'un repackage goal'u alttaki "thin" JAR'ın
                manifestini fat JAR'a propagate eder; dolayısıyla buraya
                koyduğumuz entry'ler son `mersel-dss-signer-api-X.Y.Z.jar`
                içinde de görünür.

                Standart erişim:
                  unzip -p target/*.jar META-INF/MANIFEST.MF
                Veya:
                  java -jar target/*.jar  → Spring Boot startup banner'ında
                                              Implementation-Version basılır.

                Entry'ler 'Reproducible JAR' rehberinde önerilen alanlar:
                - Implementation-Vendor / Implementation-Title /
                  Implementation-Version → JEP-238 multi-release JAR /
                  Java Package Versioning spec'ine uyum.
                - Build-Revision (git SHA) ve Build-Time → SLSA Level 2
                  provenance şartını JAR-side karşılar (Release workflow
                  tarafında SLSA attestation üretilir).
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <!--
                    combine.self="override" — Spring Boot starter-parent
                    pluginManagement bloğu maven-jar-plugin'e kendi
                    <archive><manifestEntries><Build-Time>${maven.build.timestamp}
                    </Build-Time></manifestEntries> entry'sini ekler.
                    Default Maven plugin-merge davranışında effective POM'da
                    iki Build-Time entry'si oluşur ve parent'inki kazanır;
                    bizim -Dbuild.timestamp= override'ımız sessizce gözardı
                    edilir. combine.self="override" ile parent'taki entry'leri
                    tamamen değiştirip kendi setimizi koyuyoruz.
                -->
                <configuration>
                    <archive>
                        <manifestEntries combine.self="override">
                            <Implementation-Title>${project.name}</Implementation-Title>
                            <Implementation-Version>${project.version}</Implementation-Version>
                            <Implementation-Vendor>Mersel DSS</Implementation-Vendor>
                            <Specification-Title>Mersel DSS Server Signer API</Specification-Title>
                            <Specification-Version>${project.version}</Specification-Version>
                            <Build-Time>${mersel.build.timestamp}</Build-Time>
                            <Build-Revision>${mersel.build.revision}</Build-Revision>
                            <Build-Number>${mersel.build.number}</Build-Number>
                            <Build-Host>${mersel.build.host}</Build-Host>
                            <Build-Jdk>${java.version}</Build-Jdk>
                            <Built-By>mersel-dss-ci</Built-By>
                            <X-Mersel-Project>${project.groupId}:${project.artifactId}</X-Mersel-Project>
                        </manifestEntries>
                    </archive>
                </configuration>
            </plugin>

            <!--
                CycloneDX SBOM Plugin — Software Bill of Materials.
                ==========================================================
                Çıktı: target/bom.json (CycloneDX 1.5 spec, JSON)
                       target/bom.xml  (CycloneDX 1.5 spec, XML)

                SBOM, supply-chain transparency için artık endüstri standardı:
                - NIST SSDF (SP 800-218) önerisi
                - EU Cyber Resilience Act (CRA) zorunluluğu (2027 itibariyle)
                - SLSA Level 3 build provenance şartı

                Her release'de GitHub Release asset olarak yayınlanır;
                downstream consumer'lar `cyclonedx-cli` veya OWASP
                Dependency-Track ile CVE tarama yapabilir.

                'package' phase'ine bind ettik — `mvn package` koştuğunda
                otomatik üretilir. 2.8.0 sürümü Java 8 baseline ile uyumlu.
            -->
            <plugin>
                <groupId>org.cyclonedx</groupId>
                <artifactId>cyclonedx-maven-plugin</artifactId>
                <version>2.8.0</version>
                <executions>
                    <execution>
                        <id>make-sbom</id>
                        <phase>package</phase>
                        <goals>
                            <goal>makeAggregateBom</goal>
                        </goals>
                    </execution>
                </executions>
                <configuration>
                    <projectType>application</projectType>
                    <schemaVersion>1.5</schemaVersion>
                    <includeBomSerialNumber>true</includeBomSerialNumber>
                    <includeCompileScope>true</includeCompileScope>
                    <includeProvidedScope>true</includeProvidedScope>
                    <includeRuntimeScope>true</includeRuntimeScope>
                    <includeSystemScope>false</includeSystemScope>
                    <includeTestScope>false</includeTestScope>
                    <includeLicenseText>false</includeLicenseText>
                    <outputFormat>all</outputFormat>
                    <outputName>bom</outputName>
                </configuration>
            </plugin>

            <!--
                Surefire — JUnit 5 tag tabanlı izolasyon.

                Varsayılan 'mvn test' koşusunda 'verifier-e2e' ve
                'pkcs11-integration' tag'li testler ATLANIR. Bunun nedeni:
                verifier-e2e Docker'a ihtiyaç duyar ve ghcr.io'dan ~700MB'lık
                verifier imajını çeker; pkcs11-integration ise native
                SoftHSM2/OpenSC araçları gerektirir.

                Kullanım:
                  - Sadece unit testler (default):
                      mvn test
                  - SADECE E2E (verifier roundtrip):
                      mvn test -Dgroups=verifier-e2e -DexcludedGroups=
                  - SADECE SoftHSM2 PKCS#11 integration:
                      mvn test -Dgroups=pkcs11-integration -DexcludedGroups=
                  - Hepsi:
                      mvn test -DexcludedGroups=
            -->
            <!--
                Surefire 3.2.5: Spring Boot 2.x parent default'u 2.22.2'dir;
                bu sürüm @ParameterizedTest hata raporlamasını silently
                strip ediyor (gerçek stack trace yerine "Caused by: NPE"
                gibi tek satır). 3.x bunu düzeltir, Jupiter 5.8.2 ile
                tam uyumlu.

                argLine: -XX:-OmitStackTraceInFastThrow → JIT'in
                tekrarlanan exception stack'lerini sıkıştırmasını kapatır,
                CI dump'larında her zaman tam stack alırız.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
                <configuration>
                    <excludedGroups>${excludedGroups}</excludedGroups>
                    <!--
                        argLine bileşenleri (sıra önemli):
                          1) @{argLine}        → JaCoCo prepare-agent goal'unun
                                                 runtime'da inject ettiği -javaagent
                                                 (line/branch coverage için).
                                                 '@{...}' late-evaluation; '${...}'
                                                 erken-evaluation olduğundan JaCoCo
                                                 inject'i kaybolurdu.
                          2) -XX:-OmitStackTraceInFastThrow → JIT'in tekrarlanan
                                                 exception stack'lerini sıkıştırmasını
                                                 kapatır (tam stack CI dump'ında her
                                                 zaman görünsün).
                          3) -javaagent:aspectjweaver → Allure 2.x'in @Step / @Epic /
                                                 @Feature / Allure.addAttachment()
                                                 çağrılarını runtime'da yakalaması
                                                 için zorunlu. Path'i Maven local
                                                 repo'dan resolve ediyoruz, aspectj
                                                 dependency yukarıda test scope'da
                                                 declare edilmiş.
                    -->
                    <argLine>@{argLine} -XX:-OmitStackTraceInFastThrow -javaagent:"${settings.localRepository}/org/aspectj/aspectjweaver/${aspectj.version}/aspectjweaver-${aspectj.version}.jar"</argLine>
                    <!--
                        Allure JUnit 5 entegrasyonu: allure-junit5 dependency
                        kendisi auto-register olur; ayrıca Allure'un results
                        directory'sini default 'allure-results' yerine target/
                        altına aldırıyoruz ki mvn clean ile temizlensin.
                    -->
                    <systemPropertyVariables>
                        <allure.results.directory>${project.build.directory}/allure-results</allure.results.directory>
                    </systemPropertyVariables>
                    <!--
                        SOFTHSM2_CONF: JVM seviyesinde set edilmeli. PKCS#11
                        entegrasyon testleri token'ları subprocess (softhsm2-util,
                        pkcs11-tool) ile yaratır ancak imzalama anında JVM JNI
                        ile libsofthsm2'yi yükler. JVM env'inde SOFTHSM2_CONF
                        YOKSA libsofthsm2 default sistem config'ini
                        (/etc/softhsm/softhsm2.conf veya ~/.config/softhsm2/
                        softhsm2.conf) okur ve testte yaratılan token'ı GÖRMEZ
                        → "PKCS11_SLOT=... için token bulunamadı" hatası verir.
                        Bu env subprocess'lere de propagate edilir; böylece
                        CLI ile JVM aynı config dosyasını ve token deposunu
                        paylaşır.
                    -->
                    <environmentVariables>
                        <SOFTHSM2_CONF>${project.build.directory}/softhsm-test/softhsm2.conf</SOFTHSM2_CONF>
                    </environmentVariables>
                </configuration>
            </plugin>

            <!--
                JaCoCo — line/branch/method coverage. Surefire argLine'ına
                runtime'da -javaagent inject eder (prepare-agent goal); test
                bittiğinde execution data'yı işleyip HTML report üretir
                (report goal). Pages/coverage/ altında publish edilir.

                Java 8 baseline: 0.8.11 son Java 8 uyumlu versiyon.
            -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.11</version>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <!--
                Allure Maven Plugin — allure-results/ JSON dump'ından
                offline HTML report üretir (allure:report goal). CI'da
                history/ klasörü actions/cache@v4 ile previous-build
                içeriği restore edilirse trend grafiği zenginleşir.
                Goal'u explicit invoke ediyoruz (workflow'da); phase'e
                bind etmiyoruz ki normal 'mvn test' koşumunda overhead
                yaratmasın.
            -->
            <plugin>
                <groupId>io.qameta.allure</groupId>
                <artifactId>allure-maven</artifactId>
                <version>2.12.0</version>
                <configuration>
                    <resultsDirectory>${project.build.directory}/allure-results</resultsDirectory>
                    <reportDirectory>${project.build.directory}/site/allure-maven-plugin</reportDirectory>
                    <reportVersion>${allure.version}</reportVersion>
                </configuration>
            </plugin>

            <!--
                maven-resources-plugin — src/test/resources/categories.json
                dosyasını Allure'un beklediği yere (target/allure-results/)
                kopyalar.

                Allure raporlama protokolü: categories.json allure-results/
                dizininde aranır (junit5 adapter classpath'tan otomatik kopyalama
                YAPMAZ). Bu kopya 'process-test-resources' phase'inde, Surefire
                tetiklenmeden önce çalışır → her test koşumunda dosya yerinde
                olur. 'mvn clean' sonrası da tekrar oluşur.

                Override: dosyayı yeniden adlandırıp src/test/resources/allure/
                altına taşımak istersen <directory> ve <includes> güncellenmeli.
                Şu an root-level categories.json bilinçli — Allure ekosisteminin
                en yaygın kullanılan yol pattern'i.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <version>3.3.1</version>
                <executions>
                    <execution>
                        <id>copy-allure-categories</id>
                        <phase>process-test-resources</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/allure-results</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>src/test/resources</directory>
                                    <includes>
                                        <include>categories.json</include>
                                    </includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!--
                OWASP Dependency-Check — CVE bilinen 3rd-party dependency
                tarama. HTML + JSON output. NVD-API key environment'tan
                opsiyonel okunur (CI'da secret olarak set edilebilir,
                yoksa rate-limited ama yine çalışır).

                'check' goal'unu phase'e bind ETMİYORUZ — workflow explicit
                invoke eder; default 'mvn verify' koşumunda 5+ dakika
                eklemesi istenmiyor.

                failBuildOnCVSS=11: CVSS skoru max 10'dur; 11 → asla
                fail etme. Rapor info-only; auditor için kanıt, build
                gatekeeper değil.
            -->
            <plugin>
                <groupId>org.owasp</groupId>
                <artifactId>dependency-check-maven</artifactId>
                <version>9.2.0</version>
                <configuration>
                    <failBuildOnCVSS>11</failBuildOnCVSS>
                    <formats>
                        <format>HTML</format>
                        <format>JSON</format>
                    </formats>
                    <nvdApiKey>${env.NVD_API_KEY}</nvdApiKey>
                    <!--
                        NVD veri dosyasını cwd-relative bir konuma değil
                        ~/.m2/repository altına yazıyoruz; GitHub Actions
                        cache hit'inde re-download yapmayalım (~5 dk
                        tasarruf).
                    -->
                    <dataDirectory>${settings.localRepository}/org/owasp/dependency-check-data</dataDirectory>
                    <suppressionFiles>
                        <!-- İleride false-positive'leri buraya konabilir -->
                    </suppressionFiles>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
