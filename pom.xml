    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <!--
                    `mvn spring-boot:run` çalıştırıldığında otomatik olarak
                    'local' Spring profile'ı aktif olur → src/main/resources/
                    application-local.properties yüklenir → test PFX + dummy
                    config ile uygulama hemen ayağa kalkar. Geliştirici
                    elle PFX_PATH / CERTIFICATE_PIN env var set etmek
                    zorunda kalmaz.

                    Production deployment'ları `java -jar` ile çalıştırılır
                    (bu plugin'in goal'lerini değil); orada profile aktif
                    olmaz, prod-grade env var'lar zorunlu kalır.
                -->
                <configuration>
                    <profiles>
                        <profile>local</profile>
                    </profiles>
                </configuration>
                <executions>
                    <execution>
                        <configuration>
                            <mainClass>io.mersel.dss.signer.api.SignatureApplication</mainClass>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!--
                Surefire — JUnit 5 tag tabanlı izolasyon.

                Varsayılan 'mvn test' koşusunda 'verifier-e2e' ve
                'pkcs11-integration' tag'li testler ATLANIR. Bunun nedeni:
                verifier-e2e Docker'a ihtiyaç duyar ve ghcr.io'dan ~700MB'lık
                verifier imajını çeker; pkcs11-integration ise native
                SoftHSM2/OpenSC araçları gerektirir.

                Kullanım:
                  - Sadece unit testler (default):
                      mvn test
                  - SADECE E2E (verifier roundtrip):
                      mvn test -Dgroups=verifier-e2e -DexcludedGroups=
                  - SADECE SoftHSM2 PKCS#11 integration:
                      mvn test -Dgroups=pkcs11-integration -DexcludedGroups=
                  - Hepsi:
                      mvn test -DexcludedGroups=
            -->
            <!--
                Surefire 3.2.5: Spring Boot 2.x parent default'u 2.22.2'dir;
                bu sürüm @ParameterizedTest hata raporlamasını silently
                strip ediyor (gerçek stack trace yerine "Caused by: NPE"
                gibi tek satır). 3.x bunu düzeltir, Jupiter 5.8.2 ile
                tam uyumlu.

                argLine: -XX:-OmitStackTraceInFastThrow → JIT'in
                tekrarlanan exception stack'lerini sıkıştırmasını kapatır,
                CI dump'larında her zaman tam stack alırız.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
                <configuration>
                    <excludedGroups>${excludedGroups}</excludedGroups>
                    <!--
                        argLine bileşenleri (sıra önemli):
                          1) @{argLine}        → JaCoCo prepare-agent goal'unun
                                                 runtime'da inject ettiği -javaagent
                                                 (line/branch coverage için).
                                                 '@{...}' late-evaluation; '${...}'
                                                 erken-evaluation olduğundan JaCoCo
                                                 inject'i kaybolurdu.
                          2) -XX:-OmitStackTraceInFastThrow → JIT'in tekrarlanan
                                                 exception stack'lerini sıkıştırmasını
                                                 kapatır (tam stack CI dump'ında her
                                                 zaman görünsün).
                          3) -javaagent:aspectjweaver → Allure 2.x'in @Step / @Epic /
                                                 @Feature / Allure.addAttachment()
                                                 çağrılarını runtime'da yakalaması
                                                 için zorunlu. Path'i Maven local
                                                 repo'dan resolve ediyoruz, aspectj
                                                 dependency yukarıda test scope'da
                                                 declare edilmiş.
                    -->
                    <argLine>@{argLine} -XX:-OmitStackTraceInFastThrow -javaagent:"${settings.localRepository}/org/aspectj/aspectjweaver/${aspectj.version}/aspectjweaver-${aspectj.version}.jar"</argLine>
                    <!--
                        Allure JUnit 5 entegrasyonu: allure-junit5 dependency
                        kendisi auto-register olur; ayrıca Allure'un results
                        directory'sini default 'allure-results' yerine target/
                        altına aldırıyoruz ki mvn clean ile temizlensin.
                    -->
                    <systemPropertyVariables>
                        <allure.results.directory>${project.build.directory}/allure-results</allure.results.directory>
                    </systemPropertyVariables>
                    <!--
                        SOFTHSM2_CONF: JVM seviyesinde set edilmeli. PKCS#11
                        entegrasyon testleri token'ları subprocess (softhsm2-util,
                        pkcs11-tool) ile yaratır ancak imzalama anında JVM JNI
                        ile libsofthsm2'yi yükler. JVM env'inde SOFTHSM2_CONF
                        YOKSA libsofthsm2 default sistem config'ini
                        (/etc/softhsm/softhsm2.conf veya ~/.config/softhsm2/
                        softhsm2.conf) okur ve testte yaratılan token'ı GÖRMEZ
                        → "PKCS11_SLOT=... için token bulunamadı" hatası verir.
                        Bu env subprocess'lere de propagate edilir; böylece
                        CLI ile JVM aynı config dosyasını ve token deposunu
                        paylaşır.
                    -->
                    <environmentVariables>
                        <SOFTHSM2_CONF>${project.build.directory}/softhsm-test/softhsm2.conf</SOFTHSM2_CONF>
                    </environmentVariables>
                </configuration>
            </plugin>

            <!--
                JaCoCo — line/branch/method coverage. Surefire argLine'ına
                runtime'da -javaagent inject eder (prepare-agent goal); test
                bittiğinde execution data'yı işleyip HTML report üretir
                (report goal). Pages/coverage/ altında publish edilir.

                Java 8 baseline: 0.8.11 son Java 8 uyumlu versiyon.
            -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.11</version>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <!--
                Allure Maven Plugin — allure-results/ JSON dump'ından
                offline HTML report üretir (allure:report goal). CI'da
                history/ klasörü actions/cache@v4 ile previous-build
                içeriği restore edilirse trend grafiği zenginleşir.
                Goal'u explicit invoke ediyoruz (workflow'da); phase'e
                bind etmiyoruz ki normal 'mvn test' koşumunda overhead
                yaratmasın.
            -->
            <plugin>
                <groupId>io.qameta.allure</groupId>
                <artifactId>allure-maven</artifactId>
                <version>2.12.0</version>
                <configuration>
                    <resultsDirectory>${project.build.directory}/allure-results</resultsDirectory>
                    <reportDirectory>${project.build.directory}/site/allure-maven-plugin</reportDirectory>
                    <reportVersion>${allure.version}</reportVersion>
                </configuration>
            </plugin>

            <!--
                OWASP Dependency-Check — CVE bilinen 3rd-party dependency
                tarama. HTML + JSON output. NVD-API key environment'tan
                opsiyonel okunur (CI'da secret olarak set edilebilir,
                yoksa rate-limited ama yine çalışır).

                'check' goal'unu phase'e bind ETMİYORUZ — workflow explicit
                invoke eder; default 'mvn verify' koşumunda 5+ dakika
                eklemesi istenmiyor.

                failBuildOnCVSS=11: CVSS skoru max 10'dur; 11 → asla
                fail etme. Rapor info-only; auditor için kanıt, build
                gatekeeper değil.
            -->
            <plugin>
                <groupId>org.owasp</groupId>
                <artifactId>dependency-check-maven</artifactId>
                <version>9.2.0</version>
                <configuration>
                    <failBuildOnCVSS>11</failBuildOnCVSS>
                    <formats>
                        <format>HTML</format>
                        <format>JSON</format>
                    </formats>
                    <nvdApiKey>${env.NVD_API_KEY}</nvdApiKey>
                    <!--
                        NVD veri dosyasını cwd-relative bir konuma değil
                        ~/.m2/repository altına yazıyoruz; GitHub Actions
                        cache hit'inde re-download yapmayalım (~5 dk
                        tasarruf).
                    -->
                    <dataDirectory>${settings.localRepository}/org/owasp/dependency-check-data</dataDirectory>
                    <suppressionFiles>
                        <!-- İleride false-positive'leri buraya konabilir -->
                    </suppressionFiles>
                </configuration>
            </plugin>
        </plugins>
    </build>
