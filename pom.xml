        <!--
            AspectJ Weaver — Allure'un @Step, @Attachment ve life-cycle
            annotation'larını intercept etmek için javaagent olarak yükleniyor.
            Surefire argLine'da bu JAR'ın yolu inject ediliyor. Test scope
            yeterli; production'a paketlenmez.
        -->
        <dependency>
