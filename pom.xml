        <!--
            Reproducible build + immutable release metadata
            ================================================
            Bu property'ler, üretilen JAR'ın MANIFEST.MF ve Spring Boot
            META-INF/build-info.properties (→ /actuator/info) dosyalarına
            gömülür. Lokal build'te literal "local"/"local-build" default'u
            devrede; CI/CD release akışında -D ile override edilir.
            Override edilen property'ler:
              mersel.build.revision   = git commit SHA (örn. GITHUB_SHA)
              mersel.build.number     = CI run number (örn. GITHUB_RUN_NUMBER)
              mersel.build.timestamp  = ISO-8601 UTC timestamp (son commit author date)
              mersel.build.host       = runner OS+arch
              project.build.outputTimestamp = aynı timestamp (jar mtime sabitler)

            ÖNEMLI #1: Property adlarını 'mersel.build.*' prefix'i ile tuttuk
            (sade 'build.timestamp' DEĞİL). Çünkü Spring Boot starter-parent'in
            pluginManagement block'undaki maven-jar-plugin config'i 'build.*'
            namespace altında implicit special-cased değişkenler kullanıyor;
            'build.timestamp' adlı bir property maven-archiver'ın manifest
            interpolation katmanında ÖZELDIR ve her zaman ${maven.build.timestamp}
            built-in'ine fallback eder. 'mersel.build.timestamp' ise tamamen
            user-defined namespace, -D override sessiz drop edilmez.

            ÖNEMLI #2: Default'lar literal ('local-build' vb.) — Maven
            ${maven.build.timestamp} referansını POM-read aşamasında eager
            evaluate eder ve CLI -D override'ı sessizce gözardı edilebilir
            (MNG-7314 türevi davranış). Literal default lokal geliştirici
            JAR'ında "Build-Time: local-build" gösterir (bu CI'dan değil
            sinyali), CI'da -D ile explicit ISO-8601 timestamp override.

            'project.build.outputTimestamp' Maven 3.6.1+ "Reproducible
            Builds" sinyalidir (jar/zip entry mtime'larını sabitler).
            Default 2025-01-01 epoch; release workflow'unda son commit
            tarihiyle override edilir.
        -->
        <maven.build.timestamp.format>yyyy-MM-dd'T'HH:mm:ss'Z'</maven.build.timestamp.format>
        <mersel.build.revision>local</mersel.build.revision>
        <mersel.build.number>0</mersel.build.number>
        <mersel.build.timestamp>local-build</mersel.build.timestamp>
        <mersel.build.host>local</mersel.build.host>
        <project.build.outputTimestamp>2025-01-01T00:00:00Z</project.build.outputTimestamp>
