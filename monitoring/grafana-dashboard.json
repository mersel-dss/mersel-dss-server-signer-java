{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Mersel signer metriklerini scrape eden Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["mersel", "signer", "pkcs11"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Mersel DSS Signer — Bridge & Signing",
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Instance",
        "multi": false,
        "name": "instance",
        "options": [],
        "query": "label_values(up{job=~\"mersel-signer|sign-api\"}, instance)",
        "refresh": 2,
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Belge Tipi",
        "multi": true,
        "name": "document_type",
        "options": [],
        "query": "label_values(signer_signatures_total{instance=~\"$instance\"}, document_type)",
        "refresh": 2,
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }
    ]
  },
  "panels": [
    { "type": "row", "title": "PKCS#11 Köprü", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 1, "collapsed": false, "panels": [] },

    {
      "type": "stat", "title": "Helper Ayakta", "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "pkcs11_bridge_helper_alive{instance=~\"$instance\"}" } ],
      "fieldConfig": { "defaults": {
        "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ],
        "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
      }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "IPC Sağlıklı", "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "pkcs11_bridge_ipc_healthy{instance=~\"$instance\"}" } ],
      "fieldConfig": { "defaults": {
        "mappings": [ { "type": "value", "options": { "0": { "text": "BOZUK", "color": "red" }, "1": { "text": "OK", "color": "green" } } } ],
        "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
      }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Heartbeat Açık", "id": 4,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "pkcs11_bridge_heartbeat_enabled{instance=~\"$instance\"}" } ],
      "fieldConfig": { "defaults": {
        "mappings": [ { "type": "value", "options": { "0": { "text": "KAPALI", "color": "text" }, "1": { "text": "AÇIK", "color": "green" } } } ],
        "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null }, { "color": "green", "value": 1 } ] }
      }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Ardışık HB Hata", "id": 5,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "pkcs11_bridge_heartbeat_consecutive_failures{instance=~\"$instance\"}" } ],
      "fieldConfig": { "defaults": {
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 4 } ] }
      }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Reinit Hata (toplam)", "id": 6,
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "pkcs11_bridge_heartbeat_reinit_failures{instance=~\"$instance\"}" } ],
      "fieldConfig": { "defaults": {
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
      }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Başarılı İşlem (toplam)", "id": 7,
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "pkcs11_bridge_successful_operations_total{instance=~\"$instance\"}" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    {
      "type": "timeseries", "title": "Köprü İşlem Hızı (ops/s)", "id": 8,
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "rate(pkcs11_bridge_successful_operations_total{instance=~\"$instance\"}[5m])", "legendFormat": "{{instance}}" } ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "title": "Heartbeat: başarı / hata hızı", "id": 9,
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "rate(pkcs11_bridge_heartbeat_success{instance=~\"$instance\"}[5m])", "legendFormat": "success" },
        { "refId": "B", "expr": "rate(pkcs11_bridge_heartbeat_failure{instance=~\"$instance\"}[5m])", "legendFormat": "failure" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    { "type": "row", "title": "İmza Uçları (HTTP)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 }, "id": 10, "collapsed": false, "panels": [] },

    {
      "type": "timeseries", "title": "İstek Hızı (uri bazında)", "id": 11,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum by (uri) (rate(http_server_requests_seconds_count{instance=~\"$instance\"}[5m]))", "legendFormat": "{{uri}}" } ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "title": "Gecikme p95 (uri bazında)", "id": 12,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{instance=~\"$instance\"}[5m])))", "legendFormat": "{{uri}}" } ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "title": "5xx Hata Hızı", "id": 13,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum by (uri, status) (rate(http_server_requests_seconds_count{instance=~\"$instance\", status=~\"5..\"}[5m]))", "legendFormat": "{{status}} {{uri}}" } ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 }, "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    { "type": "row", "title": "JVM / Sistem", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }, "id": 14, "collapsed": false, "panels": [] },

    {
      "type": "timeseries", "title": "Heap Kullanımı", "id": 15,
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sum(jvm_memory_used_bytes{instance=~\"$instance\", area=\"heap\"})", "legendFormat": "used" },
        { "refId": "B", "expr": "sum(jvm_memory_max_bytes{instance=~\"$instance\", area=\"heap\"})", "legendFormat": "max" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "title": "GC Duraklama Hızı", "id": 16,
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "rate(jvm_gc_pause_seconds_sum{instance=~\"$instance\"}[5m])", "legendFormat": "{{action}}" } ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "title": "CPU Kullanımı", "id": 17,
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "process_cpu_usage{instance=~\"$instance\"}", "legendFormat": "process" },
        { "refId": "B", "expr": "system_cpu_usage{instance=~\"$instance\"}", "legendFormat": "system" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "stat", "title": "Uptime", "id": 18,
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "process_uptime_seconds{instance=~\"$instance\"}" } ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Canlı Thread", "id": 19,
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "jvm_threads_live_threads{instance=~\"$instance\"}" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    { "type": "row", "title": "İmza İş Metrikleri", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 }, "id": 20, "collapsed": false, "panels": [] },

    {
      "type": "stat", "title": "Toplam İmza (başarılı)", "id": 21,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum(signer_signatures_total{instance=~\"$instance\", outcome=\"success\"})" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Toplam Hata", "id": 22,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum(signer_signatures_total{instance=~\"$instance\", outcome=\"failure\"})" } ],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Başarı Oranı", "id": 23,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "100 * sum(signer_signatures_total{instance=~\"$instance\", outcome=\"success\"}) / clamp_min(sum(signer_signatures_total{instance=~\"$instance\"}), 1)" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 95 }, { "color": "green", "value": 99 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "İmza Hızı (ops/s)", "id": 24,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum(rate(signer_signatures_total{instance=~\"$instance\", outcome=\"success\"}[5m]))" } ],
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Ort. Girdi Boyutu", "id": 25,
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum(signer_document_bytes_sum{instance=~\"$instance\"}) / clamp_min(sum(signer_document_bytes_count{instance=~\"$instance\"}), 1)" } ],
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Ort. Çıktı Boyutu", "id": 26,
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum(signer_signed_bytes_sum{instance=~\"$instance\"}) / clamp_min(sum(signer_signed_bytes_count{instance=~\"$instance\"}), 1)" } ],
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    {
      "type": "timeseries", "title": "Format Bazında İmza Hızı", "id": 27,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum by (format) (rate(signer_signatures_total{instance=~\"$instance\", outcome=\"success\"}[5m]))", "legendFormat": "{{format}}" } ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } }, "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "piechart", "title": "Format Dağılımı (toplam başarılı)", "id": 28,
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum by (format) (signer_signatures_total{instance=~\"$instance\", outcome=\"success\"})", "legendFormat": "{{format}}", "instant": true } ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "right", "values": ["value", "percent"] }, "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "bargauge", "title": "Profil Bazında Toplam", "id": 29,
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum by (profile) (signer_signatures_total{instance=~\"$instance\", outcome=\"success\"})", "legendFormat": "{{profile}}", "instant": true } ],
      "fieldConfig": { "defaults": { "color": { "mode": "continuous-GrYlRd" } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    {
      "type": "timeseries", "title": "Belge Tipi Bazında İmza Hızı (XAdES)", "id": 30,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 47 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum by (document_type) (rate(signer_signatures_total{instance=~\"$instance\", format=\"XAdES\", outcome=\"success\"}[5m]))", "legendFormat": "{{document_type}}" } ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } }, "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "title": "Başarı / Hata Hızı (format)", "id": 31,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 47 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sum by (format) (rate(signer_signatures_total{instance=~\"$instance\", outcome=\"success\"}[5m]))", "legendFormat": "ok {{format}}" },
        { "refId": "B", "expr": "sum by (format) (rate(signer_signatures_total{instance=~\"$instance\", outcome=\"failure\"}[5m]))", "legendFormat": "hata {{format}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [ { "matcher": { "id": "byRegexp", "options": "/^hata/" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } }
    },

    {
      "type": "heatmap", "title": "Girdi Belge Boyutu Dağılımı (heatmap)", "id": 32,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 55 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum by (le) (rate(signer_document_bytes_bucket{instance=~\"$instance\"}[5m]))", "legendFormat": "{{le}}", "format": "heatmap" } ],
      "options": { "calculate": false, "yAxis": { "unit": "bytes", "axisPlacement": "left" }, "color": { "scheme": "Oranges", "mode": "scheme" }, "cellGap": 1, "tooltip": { "show": true, "yHistogram": true }, "legend": { "show": true } },
      "fieldConfig": { "defaults": { "custom": { "scaleDistribution": { "type": "linear" } } }, "overrides": [] }
    },
    {
      "type": "timeseries", "title": "Girdi Belge Boyutu p50 / p95 (format)", "id": 33,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 55 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
