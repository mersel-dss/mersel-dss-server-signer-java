<component name="ProjectRunConfigurationManager">
  <!--
    TÜBİTAK Mali Mühür AKİS (Linux) ile çalıştırır.

    ÖN KOŞUL: AKİS Linux sürücüsü kurulu + pcscd çalışıyor + kart takılı +
    repo kökünde `local-secrets.properties` dosyası mevcut.

    CREDENTIAL YÖNETİMİ:
      CERTIFICATE_PIN / CERTIFICATE_ALIAS / CERTIFICATE_SERIAL_NUMBER bu run
      config XML'inde TAŞINMAZ — kart-bağımlı, geliştirici-bağımlı ve gizli.
      Onun yerine `application-mali-muhur-akis-linux.properties`,
      `spring.config.import=optional:file:./local-secrets.properties` ile
      gitignored bir dosyadan yükler:
        1) cp local-secrets.properties.example local-secrets.properties
        2) PIN/ALIAS/SERIAL'i kendi kartına göre doldur
        3) Run'a bas — bu XML hiç değişmez, commit'e sızmaz.

    Default sürücü yolu /usr/local/lib/libakisp11.so; distro paketi farklı yere
    koyduysa `local-secrets.properties` veya OS env ile PKCS11_LIBRARY override
    edilir (ör. Ubuntu: /usr/lib/x86_64-linux-gnu/libakisp11.so).
  -->
  <configuration default="false" name="Signer - Mali Mühür AKİS (Linux)" type="SpringBootApplicationConfigurationType" factoryName="Spring Boot">
    <option name="ACTIVE_PROFILES" value="local,mali-muhur-akis-linux" />
    <option name="ALTERNATIVE_JRE_PATH" value="1.8" />
    <option name="ALTERNATIVE_JRE_PATH_ENABLED" value="true" />
    <module name="mersel-dss-signer-api" />
    <option name="SPRING_BOOT_MAIN_CLASS" value="io.mersel.dss.signer.api.SignatureApplication" />
    <option name="WORKING_DIRECTORY" value="file://$PROJECT_DIR$" />
    <method v="2">
      <option name="Make" enabled="true" />
    </method>
  </configuration>
</component>
