<component name="ProjectRunConfigurationManager">
  <!--
    TÜBİTAK Mali Mühür AKİS (Windows) ile çalıştırır.

    ÖN KOŞUL: AKİS Windows kurulu (SCardSvr çalışır durumda) + kart takılı.
    Default path C:/Windows/System32/akisp11.dll; farklı kurulumlar için
    PKCS11_LIBRARY env'iyle override edilir.
  -->
  <configuration default="false" name="Signer · Mali Mühür AKİS (Windows)" type="SpringBootApplicationConfigurationType" factoryName="Spring Boot">
    <envs>
      <env name="CERTIFICATE_PIN" value="REPLACE_WITH_YOUR_PIN" />
    </envs>
    <module name="mersel-dss-signer-api" />
    <option name="SPRING_BOOT_MAIN_CLASS" value="io.mersel.dss.signer.api.SignatureApplication" />
    <option name="ACTIVE_PROFILES" value="local,mali-muhur-akis-windows" />
    <option name="ALTERNATIVE_JRE_PATH_ENABLED" value="false" />
    <option name="WORKING_DIRECTORY" value="$PROJECT_DIR$" />
    <method v="2">
      <option name="Make" enabled="true" />
    </method>
  </configuration>
</component>
