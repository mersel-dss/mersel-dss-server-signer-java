# =============================================================================
#  mersel-dss-signer.env.example — SystemD EnvironmentFile şablonu
# =============================================================================
#  Kurulum:
#    sudo mkdir -p /etc/mersel-dss-signer
#    sudo cp mersel-dss-signer.env.example /etc/mersel-dss-signer/mersel-dss-signer.env
#    sudo chown root:signer /etc/mersel-dss-signer/mersel-dss-signer.env
#    sudo chmod 0640 /etc/mersel-dss-signer/mersel-dss-signer.env
#    sudo nano /etc/mersel-dss-signer/mersel-dss-signer.env
#
#  ÖNEMLİ:
#    • Bu dosya CERTIFICATE_PIN ve TÜBİTAK parolası gibi SECRET'lar taşır.
#      Dosya izni MUTLAKA 0640 ve sahibi root:signer olmalı — okunabilir
#      olmamalı (chmod -r o-r), aksi halde "PIN düz metin" sızıntısı olur.
#    • Format: KEY=VALUE (boşluksuz, tırnaksız). systemd parse eder.
#    • Yorum satırları '#' ile başlar.
# =============================================================================

# ─── Spring Profile (opsiyonel) ─────────────────────────────────────────────
# Production'da BOŞ bırakın — default application.properties yüklenir, PFX/HSM
# için zorunlu env'leri aşağıdan verirsiniz.
# Test/staging için profile composition kullanılabilir (bkz. docs/RUN_PROFILES.md):
#   SPRING_PROFILES_ACTIVE=local,pfx-kurum01-rsa2048
#   SPRING_PROFILES_ACTIVE=local,mali-muhur-akis-linux
# SPRING_PROFILES_ACTIVE=

# ─── PFX Senaryosu (Yumuşak keystore) ───────────────────────────────────────
# Production'da PFX dosyası /etc/mersel-dss-signer/certs/ altında, dosya
# sahibi signer:signer ve izni 0400 olmalı.
# PFX_PATH=/etc/mersel-dss-signer/certs/production.pfx
# CERTIFICATE_PIN=__REPLACE_WITH_PFX_PASSWORD__
# CERTIFICATE_ALIAS=1

# ─── HSM / PKCS#11 Senaryosu (AKİS vb.) ─────────────────────────────────────
# AKİS sürücüsünün kurulu olduğu yolu verin. Ubuntu/Debian'da:
#   PKCS11_LIBRARY=/usr/lib/x86_64-linux-gnu/libakisp11.so
# RHEL/Fedora'da:
#   PKCS11_LIBRARY=/usr/lib64/libakisp11.so
# Manuel kurulum:
#   PKCS11_LIBRARY=/usr/local/lib/libakisp11.so
# PKCS11_LIBRARY=/usr/local/lib/libakisp11.so
# PKCS11_SLOT=-1
# PKCS11_SLOT_LIST_INDEX=-1
# PKCS11_NULL_INIT_ARGS=false
# CERTIFICATE_PIN=__REPLACE_WITH_HSM_PIN__
# CERTIFICATE_SERIAL_NUMBER=
# CERTIFICATE_ALIAS=

# ─── TÜBİTAK KamuSM Zaman Damgası ───────────────────────────────────────────
# Otomatik tespit aktif: TS_SERVER_HOST tubitak.gov.tr içeriyorsa
# IS_TUBITAK_TSP=true'a düşer. Açıkça override etmek için aşağıyı set edin.
# IS_TUBITAK_TSP=true
# TS_SERVER_HOST=http://zd.kamusm.gov.tr
# TS_USER_ID=__REPLACE_WITH_TSP_USER__
# TS_USER_PASSWORD=__REPLACE_WITH_TSP_PASSWORD__

# ─── XAdES SigningTime Timezone (issue #7) ──────────────────────────────────
# Default '+03:00' — TÜBİTAK MA3 referans çıktısı ve İMZAGER uyumlu.
# ETSI saf yorumu için 'Z' verin. IANA bölge de kabul edilir.
# XADES_SIGNING_TIME_ZONE=+03:00

# ─── Trusted Root (KamuSM kök sertifika deposu) ─────────────────────────────
# Online (cron ile haftalık refresh):
#   trusted.root.resolver.type=kamusm-online
# Offline (versiyonlu XML dosyası):
#   trusted.root.resolver.type=kamusm-offline
#   kamusm.root.offline.path=/etc/mersel-dss-signer/certs/SertifikaDeposu.svt
# TRUSTED_ROOT_CERT_FOLDER_PATH=/etc/mersel-dss-signer/certs/trusted-roots

# ─── Server ─────────────────────────────────────────────────────────────────
SERVER_PORT=8085

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_PATH=/var/log/mersel-dss-signer
# Production'da WARN/INFO yeterli; troubleshooting için DEBUG'a çekin.
LOG_LEVEL=INFO

# ─── CORS (production'da spesifik origin'ler) ───────────────────────────────
# CORS_ALLOWED_ORIGINS=https://admin.example.gov.tr,https://api.example.gov.tr

# ─── JVM (varsayılan unit dosyasında; burada override edilebilir) ───────────
# JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseG1GC -XX:MaxGCPauseMillis=100 -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/var/log/mersel-dss-signer
