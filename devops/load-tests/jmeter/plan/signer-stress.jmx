      <!-- ============================================================ -->
      <!-- setUp Thread Group — Path Resolution                          -->
      <!--                                                                -->
      <!-- Normal Thread Group'lardan ÖNCE çalışır. Tüm path'leri         -->
      <!-- layout-aware şekilde çözer ve properties'e yazar:              -->
      <!--   - JMeter test plan'ın bulunduğu dizini baz alır              -->
      <!--     (org.apache.jmeter.services.FileServer.getBaseDir)         -->
      <!--   - "Repo layout" (plan/ klasörü) ve "Bundle layout"           -->
      <!--     (CSV'ler plan ile aynı klasörde) otomatik algılanır        -->
      <!--   - GUI'den herhangi bir CWD'den açılsa da doğru çalışır       -->
      <!--                                                                -->
      <!-- CLI'da -Jxxx=... ile dışarıdan verilenler korunur, sadece      -->
      <!-- verilmemiş olanlar default'a düşer (override-safe).            -->
      <!-- ============================================================ -->
      <SetupThreadGroup guiclass="SetupThreadGroupGui" testclass="SetupThreadGroup" testname="setUp — Resolve Paths">
        <stringProp name="ThreadGroup.num_threads">1</stringProp>
        <stringProp name="ThreadGroup.ramp_time">1</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">stoptest</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </SetupThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Resolve Paths">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script"><![CDATA[
import org.apache.jmeter.services.FileServer

// JMeter, .jmx dosyasinin bulundugu dizini "base dir" olarak set eder.
// Bu CWD'den BAGIMSIZDIR — GUI'den acsan da CLI'dan kossan da ayni.
def planDir = FileServer.getFileServer().getBaseDir()

// Layout tespiti:
//   - BUNDLE: prepare-bundle.sh ile uretilen self-contained paket.
//     CSV'ler ve fixture klasorleri (xades/, pades/) plan ile ayni dizinde.
//   - REPO:   Gelistirme reposu. Plan devops/load-tests/jmeter/plan/'da,
//             CSV'ler devops/load-tests/jmeter/data/'da, fixture'lar repo
//             kokunden resources/test-fixtures/ altinda.
def bundleMarker = new File(planDir, "xades-fixtures.csv")
def isBundle = bundleMarker.exists()

String fixtureBaseDir, xadesCsv, padesCsv
if (isBundle) {
    fixtureBaseDir = new File(planDir).canonicalPath
    xadesCsv = new File(planDir, "xades-fixtures.csv").canonicalPath
    padesCsv = new File(planDir, "pades-fixtures.csv").canonicalPath
} else {
    // plan/ -> ../../../.. = repo root
    fixtureBaseDir = new File(planDir, "../../../..").canonicalPath
    xadesCsv = new File(planDir, "../data/xades-fixtures.csv").canonicalPath
    padesCsv = new File(planDir, "../data/pades-fixtures.csv").canonicalPath
}

// Verifier script: ARTIK INLINE (PostProcessor'in <script> CDATA'sinda).
// Sadece kullanici --verifier-script ile DISARIDAN bir dosya verirse o
// kullanilir; verilmezse property bos kalir, JMeter inline script'e duser.
// Burada default doldurmuyoruz — eski default-resolve davranisi compile
// time'da dosya yoksa patliyordu, bu davranisi devre disi birakiyoruz.

// Override-safe: -J ile verilen deger varsa dokunma, yoksa default'u set et.
def setIfMissing = { String key, String val ->
    def existing = props.get(key)
    if (existing == null || existing.toString().trim().isEmpty()) {
        props.put(key, val)
    }
}
setIfMissing("fixtureBaseDir", fixtureBaseDir)
setIfMissing("xadesCsv",       xadesCsv)
setIfMissing("padesCsv",       padesCsv)

log.info("===== Path resolution (layout=" + (isBundle ? "BUNDLE" : "REPO") + ", planDir=" + planDir + ") =====")
log.info("  FIXTURE_BASE_DIR = " + props.get("fixtureBaseDir"))
log.info("  XADES_CSV        = " + props.get("xadesCsv"))
log.info("  PADES_CSV        = " + props.get("padesCsv"))
def vs = props.get("verifierScript")
log.info("  VERIFIER_SCRIPT  = " + (vs ? vs.toString() : "(inline — JMX gomulu script)"))

// Sanity: zorunlu CSV'ler var mi? (verifier-script INLINE oldugu icin kontrol gerekmez)
def warnIfMissing = { String label, String path ->
    if (!new File(path).exists()) log.warn("[setUp] " + label + " bulunamadi: " + path)
}
warnIfMissing("XADES_CSV", props.get("xadesCsv").toString())
warnIfMissing("PADES_CSV", props.get("padesCsv").toString())
if (vs) {
    warnIfMissing("VERIFIER_SCRIPT (override)", vs.toString())
}
]]></stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>

      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="XAdES — Sustained Load">
        <stringProp name="ThreadGroup.num_threads">${XADES_THREADS}</stringProp>
