            <stringProp name="Argument.value">${__P(xadesRampup,30)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="PADES_THREADS" elementType="Argument">
            <stringProp name="Argument.name">PADES_THREADS</stringProp>
            <stringProp name="Argument.value">${__P(padesThreads,2)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="PADES_RAMPUP_SEC" elementType="Argument">
            <stringProp name="Argument.name">PADES_RAMPUP_SEC</stringProp>
            <stringProp name="Argument.value">${__P(padesRampup,5)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="PADES_RPM" elementType="Argument">
            <stringProp name="Argument.name">PADES_RPM</stringProp>
            <stringProp name="Argument.value">${__P(padesRpm,6)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="CONNECT_TIMEOUT_MS" elementType="Argument">
            <stringProp name="Argument.name">CONNECT_TIMEOUT_MS</stringProp>
            <stringProp name="Argument.value">${__P(connectTimeout,5000)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="RESPONSE_TIMEOUT_MS" elementType="Argument">
            <stringProp name="Argument.name">RESPONSE_TIMEOUT_MS</stringProp>
            <stringProp name="Argument.value">${__P(responseTimeout,60000)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <!-- ============================================================ -->
          <!-- PATH RESOLUTION — Aşağıdaki path'ler CWD-bağımsız ve           -->
          <!-- layout-aware (repo / bundle) şekilde "setUp — Resolve Paths"  -->
          <!-- thread group'unda doldurulur. Test boyunca her referans       -->
          <!-- ${__P(propName,)} ile lazy okunur (UDV intermediary YOK,      -->
          <!-- çünkü JMeter UDV'leri setUp'tan ÖNCE evaluate eder).          -->
          <!--                                                                -->
          <!-- Property → Default kaynağı:                                   -->
          <!--   fixtureBaseDir → repo root / bundle root                    -->
          <!--   xadesCsv       → <fixture base>/.../xades-fixtures.csv      -->
          <!--   padesCsv       → <fixture base>/.../pades-fixtures.csv      -->
          <!--   verifierScript → BOŞ (script JMX'in PostProcessor CDATA'sın- -->
          <!--                   da INLINE; harici dosyayla override için    -->
          <!--                   -JverifierScript=/abs/path.groovy)          -->
          <!--                                                                -->
          <!-- Hepsi -Jxxx=... ile her zaman override edilebilir.            -->
          <!-- ============================================================ -->
          <elementProp name="AUTH_HEADER" elementType="Argument">
            <stringProp name="Argument.name">AUTH_HEADER</stringProp>
            <stringProp name="Argument.value">${__P(authHeader,)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="VERIFIER_ENABLED" elementType="Argument">
