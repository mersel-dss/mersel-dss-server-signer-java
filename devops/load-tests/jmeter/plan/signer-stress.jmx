        <hashTree/>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /v1/padessign">
          <stringProp name="HTTPSampler.path">/v1/padessign</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">true</boolProp>
          <elementProp name="HTTPsampler.Files" elementType="HTTPFileArgs">
            <collectionProp name="HTTPFileArgs.files">
              <elementProp name="${padesFilePath}" elementType="HTTPFileArg">
                <stringProp name="File.path">${__P(fixtureBaseDir,)}/${padesFilePath}</stringProp>
                <stringProp name="File.paramname">Document</stringProp>
                <stringProp name="File.mimetype">${padesMimeType}</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="HTTP 200 OK" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
            <stringProp name="Assertion.custom_message">PAdES imza endpoint&apos;i 200 dönmedi</stringProp>
          </ResponseAssertion>
          <hashTree/>
          <!--
            Body'de PDF magic number (%PDF-) ara. Bu, Content-Type header'ından
            bağımsız olarak gerçek PDF dönüp dönmediğini kanıtlar:
              - Servis Content-Type set etmese bile (Spring default = octet-stream)
                veya mock servis farklı CT döndürse bile assertion çalışır.
              - Error response'lar (JSON / HTML) bu magic'i içermez → doğru fail.
            Substring (type=16) — case-sensitive, response_data alanında arar.
          -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="PDF magic number (%PDF-)" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="-1808623106">%PDF-</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">16</intProp>
            <stringProp name="Assertion.custom_message">İmzalı PDF dönmedi (response body PDF magic number içermiyor)</stringProp>
          </ResponseAssertion>
          <hashTree/>
          <!-- Verifier PostProcessor — script INLINE (XAdES ile aynı, kind=PAdES). -->
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Verify PAdES (conditional)" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters">PAdES</stringProp>
            <stringProp name="filename">${__P(verifierScript,)}</stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script"><![CDATA[
import org.apache.http.impl.client.HttpClients
import org.apache.http.client.config.RequestConfig
import org.apache.http.client.methods.HttpPost
import org.apache.http.entity.mime.MultipartEntityBuilder
import org.apache.http.entity.ContentType
import org.apache.http.util.EntityUtils
import org.apache.jmeter.samplers.SampleResult

def enabled = "true".equalsIgnoreCase((vars.get("VERIFIER_ENABLED") ?: "false").toString().trim())
if (!enabled) { return }
if (!prev.isSuccessful()) { return }

def verifierUrl = (vars.get("VERIFIER_URL") ?: "").toString().trim()
if (verifierUrl.isEmpty()) {
    log.warn("VERIFIER_ENABLED=true ama VERIFIER_URL bos — bu iterasyonda dogrulama atlandi.")
    return
}
while (verifierUrl.endsWith("/")) {
    verifierUrl = verifierUrl.substring(0, verifierUrl.length() - 1)
}

def kind = (args ?: "PAdES").toString().trim()
def isPades = kind.equalsIgnoreCase("PAdES")
def fileName = isPades ? "signed.pdf" : "signed.xml"
def contentType = isPades ? ContentType.create("application/pdf") : ContentType.create("application/xml")
def verifyLabel = "VERIFY " + kind
def level = (vars.get("VERIFIER_LEVEL") ?: "SIMPLE").toString().trim()
def timeoutMs = Integer.parseInt((vars.get("VERIFIER_TIMEOUT_MS") ?: "30000").toString().trim())

def client = props.get("__jm_verifier_client")
if (client == null) {
    synchronized (props) {
        client = props.get("__jm_verifier_client")
        if (client == null) {
            def reqConfig = RequestConfig.custom()
                .setConnectTimeout(5000)
                .setSocketTimeout(timeoutMs)
                .setConnectionRequestTimeout(5000)
                .build()
            client = HttpClients.custom()
                .setMaxConnPerRoute(500)
                .setMaxConnTotal(1000)
                .setDefaultRequestConfig(reqConfig)
                .disableAutomaticRetries()
                .build()
            props.put("__jm_verifier_client", client)
            log.info("Verifier HttpClient lazy-init OK -> " + verifierUrl)
        }
    }
}

def signedBytes = prev.getResponseData()
if (signedBytes == null || signedBytes.length == 0) {
    log.warn("Verifier: prev response body bos, dogrulama atlandi (label=" + prev.getSampleLabel() + ")")
    return
}

def subResult = new SampleResult()
subResult.setSampleLabel(verifyLabel)
subResult.setURL(new java.net.URL(verifierUrl + "/api/v1/verify/signature"))
subResult.sampleStart()

try {
    def post = new HttpPost(verifierUrl + "/api/v1/verify/signature")
    post.addHeader("Accept", "application/json")
    def auth = (vars.get("AUTH_HEADER") ?: "").toString().trim()
    if (!auth.isEmpty()) { post.addHeader("Authorization", auth) }

    def entity = MultipartEntityBuilder.create()
        .addBinaryBody("signedDocument", signedBytes, contentType, fileName)
        .addTextBody("level", level)
        .build()
    post.setEntity(entity)

    def resp = client.execute(post)
    try {
        def code = resp.getStatusLine().getStatusCode()
        def bodyEntity = resp.getEntity()
        def body = bodyEntity != null ? EntityUtils.toString(bodyEntity, "UTF-8") : ""

        subResult.setResponseCode(String.valueOf(code))
        subResult.setResponseData(body, "UTF-8")
        subResult.setDataType(SampleResult.TEXT)
        subResult.setBytes((long) (body != null ? body.length() : 0))
        subResult.setSentBytes((long) signedBytes.length)

        def looksValid = (code == 200) && body.replaceAll("\\s+", "").contains('"valid":true')
        subResult.setSuccessful(looksValid)

        if (!looksValid) {
            def snippet = body != null && body.length() > 400 ? body.substring(0, 400) + "..." : body
            subResult.setResponseMessage("Verifier rejected: HTTP " + code)
            prev.setSuccessful(false)
            prev.appendResponseMessage("\n[Verifier] INVALID signature: code=" + code + ", body=" + snippet)
        }
    } finally {
        resp.close()
    }
} catch (Throwable t) {
    subResult.setSuccessful(false)
    subResult.setResponseCode("VERIFY_ERROR")
    subResult.setResponseMessage(t.getClass().getSimpleName() + ": " + (t.getMessage() ?: ""))
    subResult.setResponseData(t.toString(), "UTF-8")
    prev.setSuccessful(false)
    prev.appendResponseMessage("\n[Verifier] request failed: " + t.toString())
} finally {
    subResult.sampleEnd()
    prev.addSubResult(subResult)
}
]]></stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>
      </hashTree>
      <!-- ============================================================ -->
      <!-- LISTENERS — GUI'de kullanışlı, CLI'da performans için disabled -->
      <!--                                                                -->
      <!-- CLI'da JMeter zaten:                                           -->
      <!--   • -l result.jtl ile her sample'ı JTL'ye yazar                -->
      <!--   • -e -o report/ ile HTML dashboard üretir                    -->
      <!--   • summariser ile terminale "summary + ..." progress basar    -->
      <!-- Bu yüzden listener'lar default'ta DISABLED. GUI'de kullanıcı   -->
      <!-- sağ tık → Enable ile bir tıkta açar.                            -->
      <!-- ============================================================ -->

      <!-- 1) View Results Tree — debug: her request/response (GUI-only) -->
      <ResultCollector guiclass="ViewResultsFullVisualizer" testclass="ResultCollector" testname="View Results Tree (debug — GUI'de Enable et)" enabled="false">
        <boolProp name="ResultCollector.error_logging">false</boolProp>
