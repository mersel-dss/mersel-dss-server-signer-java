# =============================================================================
#  mersel-dss-signer.env.example — Windows Service env şablonu
# =============================================================================
#  Bu dosya Install-Service.ps1 tarafından okunur ve mersel-dss-signer.xml
#  içindeki <env> bloklarına inject edilir. SystemD'deki EnvironmentFile'ın
#  Windows muadili.
#
#  Kurulum:
#    1) Copy-Item .\mersel-dss-signer.env.example .\mersel-dss-signer.env
#    2) Notepad++ veya VS Code ile düzenle (CRLF satır sonu)
#    3) .\Install-Service.ps1 -EnvFile .\mersel-dss-signer.env
#
#  GÜVENLİK:
#    • Dosya CERTIFICATE_PIN ve TSP parolası taşır. Production'da
#      C:\ProgramData\mersel-dss-signer\ altına koy, NTFS ACL ile yalnızca
#      LocalSystem (veya kullandığın service account) okuyabilsin.
#    • Repo'ya commit ETME — sadece .env.example commit edilir.
#    • Format: KEY=VALUE. Tırnak GEREKMEZ; XML'e geçerken otomatik escape edilir.
#    • Yorum satırı '#' ile başlar.
# =============================================================================

# ─── Spring Profile (opsiyonel) ─────────────────────────────────────────────
# Production'da BOŞ bırakın — default application.properties yüklenir.
# Test için profile composition kullanılabilir (bkz. docs\RUN_PROFILES.md):
#   SPRING_PROFILES_ACTIVE=local,pfx-kurum01-rsa2048
#   SPRING_PROFILES_ACTIVE=local,mali-muhur-akis-windows
# SPRING_PROFILES_ACTIVE=

# ─── PFX Senaryosu ──────────────────────────────────────────────────────────
# Windows path separator'ı: '\' veya '/' ikisi de kabul (Java NIO normalizes).
# PFX_PATH=C:\ProgramData\mersel-dss-signer\certs\production.pfx
# CERTIFICATE_PIN=__REPLACE_WITH_PFX_PASSWORD__
# CERTIFICATE_ALIAS=1

# ─── HSM / PKCS#11 (AKİS Windows) ───────────────────────────────────────────
# AKİS resmi installer DLL'i C:\Windows\System32 altına koyar.
# 32-bit ↔ 64-bit JVM/sürücü uyumu KRİTİK: 64-bit JVM kullanıyorsan
# akisp11.dll de 64-bit olmalı, aksi halde UnsatisfiedLinkError.
# PKCS11_LIBRARY=C:\Windows\System32\akisp11.dll
# PKCS11_SLOT=-1
# PKCS11_SLOT_LIST_INDEX=-1
# PKCS11_NULL_INIT_ARGS=false
# CERTIFICATE_PIN=__REPLACE_WITH_HSM_PIN__
# CERTIFICATE_SERIAL_NUMBER=
# CERTIFICATE_ALIAS=

# ─── TÜBİTAK KamuSM Zaman Damgası ───────────────────────────────────────────
# Otomatik tespit: TS_SERVER_HOST tubitak.gov.tr içeriyorsa IS_TUBITAK_TSP=true.
# IS_TUBITAK_TSP=true
# TS_SERVER_HOST=http://zd.kamusm.gov.tr
# TS_USER_ID=__REPLACE_WITH_TSP_USER__
# TS_USER_PASSWORD=__REPLACE_WITH_TSP_PASSWORD__

# ─── XAdES SigningTime Timezone (issue #7) ──────────────────────────────────
# Default '+03:00' — TÜBİTAK MA3 referans çıktısı ile uyumlu.
# 'Z' verirsen ETSI saf yorumu (UTC suffix) kullanılır.
# XADES_SIGNING_TIME_ZONE=+03:00

# ─── Trusted Root (KamuSM kök sertifika deposu) ─────────────────────────────
# trusted.root.resolver.type=kamusm-online
# kamusm.root.offline.path=C:\ProgramData\mersel-dss-signer\certs\SertifikaDeposu.svt
# TRUSTED_ROOT_CERT_FOLDER_PATH=C:\ProgramData\mersel-dss-signer\certs\trusted-roots

# ─── Server ─────────────────────────────────────────────────────────────────
SERVER_PORT=8085

# ─── Logging ────────────────────────────────────────────────────────────────
# WinSW kendi stdout/stderr'i %BASE%\logs altına yazar (XML'de tanımlı).
# Spring Boot logback bunu DA kullanır — aşağıdaki LOG_PATH alanı.
LOG_PATH=C:\Program Files\mersel-dss-signer\logs
LOG_LEVEL=INFO

# ─── CORS (production'da spesifik origin'ler) ───────────────────────────────
# CORS_ALLOWED_ORIGINS=https://admin.example.gov.tr,https://api.example.gov.tr

# ─── JVM (varsayılan XML'de; burada override edersen Install-Service.ps1
#         <arguments> satırını günceller) ──────────────────────────────────
# JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseG1GC -XX:MaxGCPauseMillis=100 -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=C:\ProgramData\mersel-dss-signer\heap-dumps
