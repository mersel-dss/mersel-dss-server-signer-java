# =============================================================================
#  .env.example — Docker Compose production env şablonu
# =============================================================================
#  Kullanım:
#    cp .env.example .env.production
#    nano .env.production
#    docker-compose --env-file .env.production up -d
#
#  GÜVENLİK:
#    • Bu dosya CERTIFICATE_PIN ve TSP parolası taşır. Repo'ya commit edilmez
#      (.gitignore -> .env, .env.production); sadece .env.example sürüm kontrolüne girer.
#    • Format: KEY=VALUE (boşluksuz, tırnaksız). Docker Compose parse eder.
#    • Test PFX'leri için repo'daki .env.test.kurum1 / parametreli script'ler
#      (unix/start-test-kurum.sh, windows/start-test-kurum.ps1) hazır.
# =============================================================================

# ─── Spring Profile (opsiyonel) ─────────────────────────────────────────────
# Production'da BOŞ bırakın — default application.properties yüklenir.
# Test/staging için profile composition (bkz. docs/RUN_PROFILES.md):
#   SPRING_PROFILES_ACTIVE=local,pfx-kurum01-rsa2048
# SPRING_PROFILES_ACTIVE=

# ─── PFX Senaryosu (Yumuşak keystore) ───────────────────────────────────────
# Container içi yol — docker-compose.yml'de bind-mount tanımlanır:
#   volumes:
#     - /etc/mersel-dss-signer/certs:/app/certs:ro
PFX_PATH=/app/certs/production.pfx
CERTIFICATE_PIN=__REPLACE_WITH_PFX_PASSWORD__
CERTIFICATE_ALIAS=1

# ─── HSM / PKCS#11 Senaryosu (AKİS vb.) ─────────────────────────────────────
# Container'da smart card kullanımı: kart okuyucu USB passthrough + libpcsclite
# bind-mount + privileged: true ister. Production için bu senaryo karmaşık;
# bare-metal (SystemD veya Windows Service) tercih edilir.
# PKCS11_LIBRARY=/usr/lib/x86_64-linux-gnu/libakisp11.so
# PKCS11_SLOT=-1
# PKCS11_SLOT_LIST_INDEX=-1
# PKCS11_NULL_INIT_ARGS=false
# CERTIFICATE_SERIAL_NUMBER=

# ─── TÜBİTAK KamuSM Zaman Damgası ───────────────────────────────────────────
# Otomatik tespit aktif: TS_SERVER_HOST tubitak.gov.tr içeriyorsa
# IS_TUBITAK_TSP=true'a düşer. Açıkça override etmek için aşağıyı set edin.
# IS_TUBITAK_TSP=true
# TS_SERVER_HOST=http://zd.kamusm.gov.tr
# TS_USER_ID=__REPLACE_WITH_TSP_USER__
# TS_USER_PASSWORD=__REPLACE_WITH_TSP_PASSWORD__

# ─── XAdES SigningTime Timezone (issue #7) ──────────────────────────────────
# Default '+03:00' — TÜBİTAK MA3 referans çıktısı ve İMZAGER lokal gösterimi
# ile birebir uyumlu. ETSI saf yorumu için 'Z' verin.
# XADES_SIGNING_TIME_ZONE=+03:00

# ─── Trusted Root (KamuSM kök sertifika deposu) ─────────────────────────────
# trusted.root.resolver.type=kamusm-online    # cron ile haftalık refresh
# trusted.root.resolver.type=kamusm-offline   # versiyonlu XML dosyası
# TRUSTED_ROOT_CERT_FOLDER_PATH=/app/certs/trusted-roots

# ─── Application ────────────────────────────────────────────────────────────
SERVER_PORT=8085
LOG_LEVEL=INFO
# CORS_ALLOWED_ORIGINS=https://admin.example.gov.tr,https://api.example.gov.tr

# ─── Monitoring Stack Portları (docker-compose.yml) ─────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=__REPLACE_WITH_STRONG_PASSWORD__
ALERTMANAGER_PORT=9093

# ─── JVM (docker-compose.yml'de override edilir — burada explicit verirsen
#         compose interpolation'ı için "JAVA_OPTS=..." bağlanır) ────────────
# JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseG1GC -XX:MaxGCPauseMillis=100

# ============================================================================
#  Mevcut Test Sertifikaları (repo içinde — resources/test-certs/)
# ============================================================================
#  Kurum 1 (sadece RSA):
#    testkurum01_rsa2048@test.com.tr_614573.pfx          PIN: 614573
#
#  Kurum 2 (RSA + EC-384):
#    testkurum02_rsa2048@sm.gov.tr_059025.pfx            PIN: 059025
#    testkurum02_ec384@test.com.tr_825095.pfx            PIN: 825095
#
#  Kurum 3 (RSA + EC-384):
#    testkurum03_rsa2048@test.com.tr_181193.pfx          PIN: 181193
#    testkurum03_ec384@test.com.tr_540425.pfx            PIN: 540425
#
#  Parametreli helper script'ler:
#    ./unix/start-test-kurum.sh    [kurum_no] [cert_type]    # 1..3, rsa|ec384
#    .\windows\start-test-kurum.ps1 [kurum_no] [cert_type]
# ============================================================================
